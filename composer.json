{
    "name": "wate/cake-utility",
    "description": "Utility plugin for CakePHP providing advanced YAML loading and scenario management.",
    "type": "cakephp-plugin",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "cakephp/cakephp": "^5.3",
        "symfony/yaml": "^6.0 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CakeUtility\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CakeUtility\\Test\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit tests/TestCase"
    }
}
